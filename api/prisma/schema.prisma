generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model card {
  name               String               @id @unique(map: "name_UNIQUE") @db.VarChar(32)
  type               card_type
  mana_cost          Int                  @db.UnsignedInt
  card_has_more_type card_has_more_type[]
  print              print[]
}

model collection {
  name                  String                  @db.VarChar(64)
  owner_id              Int                     @db.UnsignedInt
  id                    Int                     @unique(map: "id_UNIQUE") @default(autoincrement()) @db.UnsignedInt
  user                  user                    @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_Collections_user1")
  collections_has_print collections_has_print[]

  @@id([id, owner_id])
  @@index([owner_id], map: "fk_Collections_user1_idx")
}

model collections_has_print {
  collections_id                Int        @db.UnsignedInt
  print_card_name               String     @db.VarChar(32)
  print_expansion_formated_name String     @db.VarChar(32)
  quantity                      Int?       @db.UnsignedInt
  collection                    collection @relation(fields: [collections_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_Collections_has_print_Collections1")
  print                         print      @relation(fields: [print_card_name, print_expansion_formated_name], references: [card_name, expansion_formated_name], onDelete: NoAction, onUpdate: NoAction, map: "fk_Collections_has_print_print1")

  @@id([collections_id, print_card_name, print_expansion_formated_name])
  @@index([collections_id], map: "fk_Collections_has_print_Collections1_idx")
  @@index([print_card_name, print_expansion_formated_name], map: "fk_Collections_has_print_print1_idx")
}

model deck {
  id             Int              @unique(map: "id_UNIQUE") @default(autoincrement()) @db.UnsignedInt
  name           String           @db.VarChar(128)
  owner_id       Int              @db.UnsignedInt
  user           user             @relation(fields: [owner_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_deck_user1")
  deck_has_print deck_has_print[]

  @@id([id, owner_id])
  @@index([owner_id], map: "fk_deck_user1_idx")
}

model deck_has_print {
  print_card_name               String @db.VarChar(32)
  print_expansion_formated_name String @db.VarChar(32)
  deck_id                       Int    @db.UnsignedInt
  quantity                      Int?   @db.UnsignedInt
  deck                          deck   @relation(fields: [deck_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_deck_has_print_deck1")
  print                         print  @relation(fields: [print_card_name, print_expansion_formated_name], references: [card_name, expansion_formated_name], onDelete: NoAction, onUpdate: NoAction, map: "fk_deck_has_print_print1")

  @@id([print_card_name, print_expansion_formated_name, deck_id])
  @@index([deck_id], map: "fk_deck_has_print_deck1_idx")
  @@index([print_card_name, print_expansion_formated_name], map: "fk_deck_has_print_print1_idx")
}

model print {
  card_name               String                  @db.VarChar(32)
  expansion_formated_name String                  @db.VarChar(32)
  id                      Int                     @unique(map: "ID_UNIQUE") @db.UnsignedInt
  image_font_url          String                  @db.VarChar(255)
  image_back_url          String?                 @db.VarChar(255)
  rules                   String?                 @db.VarChar(512)
  card                    card                    @relation(fields: [card_name], references: [name], onDelete: NoAction, onUpdate: NoAction, map: "fk_print_card")
  expansion               expansion               @relation(fields: [expansion_formated_name], references: [formated_name], onDelete: NoAction, onUpdate: NoAction, map: "fk_print_expansion1")
  collections_has_print   collections_has_print[]
  deck_has_print          deck_has_print[]

  @@id([card_name, expansion_formated_name])
  @@index([expansion_formated_name], map: "fk_print_expansion1_idx")
}

model user {
  username   String       @unique(map: "nick_UNIQUE") @db.VarChar(32)
  email      String       @unique(map: "email_UNIQUE") @db.VarChar(128)
  id         Int          @id @unique(map: "id_UNIQUE") @default(autoincrement()) @db.UnsignedInt
  collection collection[]
  deck       deck[]
}

model card_has_more_type {
  card_name      String    @db.VarChar(32)
  more_type_type String    @db.VarChar(32)
  card           card      @relation(fields: [card_name], references: [name], onDelete: NoAction, onUpdate: NoAction, map: "fk_card_has_more_type_card1")
  more_type      more_type @relation(fields: [more_type_type], references: [type], onDelete: NoAction, onUpdate: NoAction, map: "fk_card_has_more_type_more_type1")

  @@id([card_name, more_type_type])
  @@index([card_name], map: "fk_card_has_more_type_card1_idx")
  @@index([more_type_type], map: "fk_card_has_more_type_more_type1_idx")
}

model expansion {
  formated_name           String  @unique(map: "formated_name_UNIQUE") @db.VarChar(32)
  name                    String  @unique(map: "name_UNIQUE") @db.VarChar(32)
  set_formated_name       String  @db.VarChar(32)
  set_block_formated_name String  @db.VarChar(32)
  set                     set     @relation(fields: [set_formated_name, set_block_formated_name], references: [formated_name, block_formated_name], onDelete: NoAction, onUpdate: NoAction, map: "fk_expansion_set1")
  print                   print[]

  @@id([formated_name, set_formated_name, set_block_formated_name])
  @@index([set_formated_name, set_block_formated_name], map: "fk_expansion_set1_idx")
}

model more_type {
  type               String               @id @unique(map: "type_UNIQUE") @db.VarChar(32)
  card_has_more_type card_has_more_type[]
}

model block {
  name          String @unique(map: "name_UNIQUE") @db.VarChar(32)
  formated_name String @id @unique(map: "formated_name_UNIQUE") @db.VarChar(32)
  set           set[]
}

model set {
  name                String      @unique(map: "name_UNIQUE") @db.VarChar(32)
  formated_name       String      @unique(map: "formated_name_UNIQUE") @db.VarChar(32)
  block_formated_name String      @db.VarChar(32)
  block               block       @relation(fields: [block_formated_name], references: [formated_name], onDelete: NoAction, onUpdate: NoAction, map: "fk_set_block1")
  expansion           expansion[]

  @@id([formated_name, block_formated_name])
  @@index([block_formated_name], map: "fk_set_block1_idx")
}

enum card_type {
  Ability
  Instant
  Equipment
  Hero
  Ally
}
